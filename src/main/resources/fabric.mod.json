{
	"schemaVersion": 1,
	"id": "magic8ball",
	"version": "${version}",
	"name": "Magic 8 Ball",
	"description": "This is a mod that brings the infamous Magic 8 Ball to minecraft. You'll be able to get simple yes or no answers for any questions that can be answered that way",
	"authors": [
		"Mrdeadlydonut"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/magic8ball/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"net.mrdeadlydonut.magic8ball.Magic8Ball"
		],
		"fabric-datagen": [
			"net.mrdeadlydonut.magic8ball.Magic8BallDataGenerator"
		]
	},
	"mixins": [
		"magic8ball.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.19.2",
		"minecraft": "~26.1.2",
		"java": ">=25",
		"fabric-api": "*"
	}
}